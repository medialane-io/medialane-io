# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL and NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL are deprecated in Clerk v6.
# Configure redirects via signInFallbackRedirectUrl / signUpFallbackRedirectUrl props instead.

# ChipiPay — JWT template must be named "chipipay"
NEXT_PUBLIC_CHIPI_API_KEY=
NEXT_PUBLIC_CLERK_TEMPLATE_NAME=chipipay

# medialane-backend
NEXT_PUBLIC_MEDIALANE_BACKEND_URL=
# Client-facing read-only key — included in the browser bundle. Read operations only.
NEXT_PUBLIC_MEDIALANE_API_KEY=
# Server-only copy of the same key — used in API routes so the value stays out of the JS bundle.
# Set to the same value as NEXT_PUBLIC_MEDIALANE_API_KEY.
MEDIALANE_API_KEY=

# Starknet
NEXT_PUBLIC_STARKNET_RPC_URL=
NEXT_PUBLIC_MARKETPLACE_CONTRACT=0x04299b51289aa700de4ce19cc77bcea8430bfd1aef04193efab09d60a3a7ee0f
NEXT_PUBLIC_COLLECTION_CONTRACT=0x05c49ee5d3208a2c2e150fdd0c247d1195ed9ab54fa2d5dea7a633f39e4b205b

# Pinata IPFS
PINATA_JWT=
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# Explorer
NEXT_PUBLIC_EXPLORER_URL=https://voyager.online

# App URL — used for metadata base URL, sitemap generation, and open-redirect validation
NEXT_PUBLIC_APP_URL=https://medialane.io

# Genesis Launch Mint
NEXT_PUBLIC_LAUNCH_MINT_CONTRACT=
NEXT_PUBLIC_GENESIS_NFT_URI=
NEXT_PUBLIC_GENESIS_NFT_IMAGE_URL=

# Admin secret for POST /api/pinata/genesis (one-time genesis metadata pre-upload)
ADMIN_SECRET=

# Airdrop waitlist — currently a stub (logs only).
# Before wiring to Resend/Mailchimp/DB, replace the in-memory rate limiter in
# src/app/api/airdrop/register/route.ts with Upstash Redis or Vercel KV.
NEXT_PUBLIC_DROP_FACTORY_CONTRACT=0x03587f42e29daee1b193f6cf83bf8627908ed6632d0d83fcb26225c50547d800
NEXT_PUBLIC_DROP_FACTORY_START_BLOCK=8341335

NEXT_PUBLIC_POP_FACTORY_CONTRACT=0x00b32c34b427d8f346b5843ada6a37bd3368d879fc752cd52b68a87287f60111
NEXT_PUBLIC_POP_FACTORY_START_BLOCK=8328934